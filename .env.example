# ============================================================
#  LOCAL DEV → docker compose up --build
#  Les images sont buildées localement, pas besoin de ces vars.
# ============================================================

# ============================================================
#  PRODUCTION → définir dans Coolify (pas dans .env)
# ============================================================

# Images buildées par CI/CD → GitLab Container Registry
BACKEND_IMAGE=registry.gitlab.com/VOTRE_USER/e5-and-dragons/backend:latest
FRONTEND_IMAGE=registry.gitlab.com/VOTRE_USER/e5-and-dragons/frontend:latest

# Webhook Coolify (Settings → Webhooks dans le service Coolify)
COOLIFY_WEBHOOK=
COOLIFY_TOKEN=
